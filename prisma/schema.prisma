// ============================================================
// Misswaxbeautycare — Schéma de base de données
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------------
// ENUMS
// ------------------------------------------------------------

enum Role {
  CLIENT
  PROFESSIONAL
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REFUSED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentType {
  DEPOSIT
  FULL
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum NotificationType {
  BOOKING_CONFIRMATION
  BOOKING_REMINDER_24H
  BOOKING_REMINDER_2H
  BOOKING_REFUSED
  BOOKING_CANCELLED
  NEW_REVIEW
  PROMOTION
  PAYMENT_RECEIVED
}

// ------------------------------------------------------------
// UTILISATEURS & RÔLES
// ------------------------------------------------------------

model User {
  id            String   @id @default(uuid())
  authId        String   @unique // id Supabase Auth (auth.users.id)
  email         String   @unique
  firstName     String
  lastName      String
  phone         String?
  avatarUrl     String?
  role          Role     @default(CLIENT)
  city          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  salon         Salon?
  bookings      Booking[]
  reviews       Review[]
  favorites     Favorite[]
  orders        Order[]
  notifications Notification[]

  @@map("users")
}

// ------------------------------------------------------------
// SALON / PROFESSIONNEL
// ------------------------------------------------------------

model Salon {
  id             String   @id @default(uuid())
  ownerId        String   @unique
  owner          User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name           String
  slug           String   @unique
  description    String?
  logoUrl        String?
  coverUrl       String?
  address        String?
  city           String
  postalCode     String?
  country        String   @default("Belgique")
  latitude       Float?
  longitude      Float?
  phone          String?
  commissionRate Float    @default(15) // % prélevé par la plateforme

  isApproved     Boolean  @default(false)
  isActive       Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  categories     SalonCategory[]
  services       Service[]
  photos         SalonPhoto[]
  openingHours   OpeningHour[]
  closedDays     ClosedDay[]
  bookings       Booking[]
  reviews        Review[]
  favorites      Favorite[]
  products       Product[]
  promotions     Promotion[]

  @@map("salons")
}

model SalonPhoto {
  id      String @id @default(uuid())
  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  url     String
  order   Int    @default(0)

  @@map("salon_photos")
}

model OpeningHour {
  id        String @id @default(uuid())
  salonId   String
  salon     Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  dayOfWeek Int    // 0 = dimanche ... 6 = samedi
  openTime  String // "09:00"
  closeTime String // "18:00"
  isClosed  Boolean @default(false)

  @@map("opening_hours")
}

model ClosedDay {
  id      String   @id @default(uuid())
  salonId String
  salon   Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  date    DateTime
  reason  String?

  @@map("closed_days")
}

// ------------------------------------------------------------
// CATÉGORIES & PRESTATIONS
// ------------------------------------------------------------

model Category {
  id    String @id @default(uuid())
  name  String @unique
  slug  String @unique
  icon  String?

  salons   SalonCategory[]
  services Service[]

  @@map("categories")
}

model SalonCategory {
  salonId    String
  salon      Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([salonId, categoryId])
  @@map("salon_categories")
}

model Service {
  id          String   @id @default(uuid())
  salonId     String
  salon       Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  name        String
  description String?
  durationMin Int      // durée en minutes
  price       Decimal  @db.Decimal(10, 2)
  depositPct  Int      @default(30) // % d'acompte si applicable
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())

  bookings    Booking[]

  @@map("services")
}

// ------------------------------------------------------------
// RÉSERVATIONS
// ------------------------------------------------------------

model Booking {
  id          String        @id @default(uuid())
  clientId    String
  client      User          @relation(fields: [clientId], references: [id])
  salonId     String
  salon       Salon         @relation(fields: [salonId], references: [id])
  serviceId   String
  service     Service       @relation(fields: [serviceId], references: [id])

  date        DateTime      // date + heure du rendez-vous
  durationMin Int
  status      BookingStatus @default(PENDING)
  notes       String?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payment     Payment?
  review      Review?
  notifications Notification[]

  @@index([salonId, date])
  @@map("bookings")
}

model Payment {
  id                    String        @id @default(uuid())
  bookingId             String        @unique
  booking               Booking       @relation(fields: [bookingId], references: [id])
  type                  PaymentType
  status                PaymentStatus @default(PENDING)
  amount                Decimal       @db.Decimal(10, 2)
  commissionAmount      Decimal       @db.Decimal(10, 2)
  stripePaymentIntentId String?       @unique
  createdAt             DateTime      @default(now())

  @@map("payments")
}

// ------------------------------------------------------------
// AVIS
// ------------------------------------------------------------

model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  clientId  String
  client    User     @relation(fields: [clientId], references: [id])
  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id])

  rating    Int      // 1 à 5
  comment   String?
  photoUrl  String?

  createdAt DateTime @default(now())

  @@map("reviews")
}

// ------------------------------------------------------------
// FAVORIS
// ------------------------------------------------------------

model Favorite {
  clientId String
  client   User   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  salonId  String
  salon    Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([clientId, salonId])
  @@map("favorites")
}

// ------------------------------------------------------------
// BOUTIQUE
// ------------------------------------------------------------

model Product {
  id          String   @id @default(uuid())
  salonId     String
  salon       Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  name        String
  description String?
  imageUrl    String?
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())

  orderItems  OrderItem[]

  @@map("products")
}

model Order {
  id          String      @id @default(uuid())
  clientId    String
  client      User        @relation(fields: [clientId], references: [id])
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2)
  stripePaymentIntentId String? @unique
  createdAt   DateTime    @default(now())

  items       OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  @@map("order_items")
}

// ------------------------------------------------------------
// PROMOTIONS
// ------------------------------------------------------------

model Promotion {
  id          String   @id @default(uuid())
  salonId     String
  salon       Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  title       String
  description String?
  discountPct Int
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())

  @@map("promotions")
}

// ------------------------------------------------------------
// NOTIFICATIONS
// ------------------------------------------------------------

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingId String?
  booking   Booking?         @relation(fields: [bookingId], references: [id])
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@map("notifications")
}
